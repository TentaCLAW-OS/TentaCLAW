# TentaCLAW OS — Default Firewall Rules
# Applied during installation via: ufw --force enable

# SSH
-A ufw-user-input -p tcp --dport 22 -j ACCEPT

# TentaCLAW Gateway API + Dashboard
-A ufw-user-input -p tcp --dport 8080 -j ACCEPT

# Ollama inference API (local network only)
-A ufw-user-input -p tcp --dport 11434 -s 10.0.0.0/8 -j ACCEPT
-A ufw-user-input -p tcp --dport 11434 -s 172.16.0.0/12 -j ACCEPT
-A ufw-user-input -p tcp --dport 11434 -s 192.168.0.0/16 -j ACCEPT

# TentaCLAW auto-discovery (UDP broadcast)
-A ufw-user-input -p udp --dport 41337 -j ACCEPT
-A ufw-user-input -p udp --dport 41338 -j ACCEPT

# Prometheus metrics (local network only)
-A ufw-user-input -p tcp --dport 9090 -s 10.0.0.0/8 -j ACCEPT
-A ufw-user-input -p tcp --dport 9090 -s 172.16.0.0/12 -j ACCEPT
-A ufw-user-input -p tcp --dport 9090 -s 192.168.0.0/16 -j ACCEPT
