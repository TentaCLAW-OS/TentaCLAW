# === CLI Build ===
cli/dist/
cli/node_modules/

# === OS ===
*.o
*.so
*.ko
*.mod.c
*.cmd
Module.symvers
modules.order

# === Editor / Tools ===
.vscode/
.vs/
.idea/
.claude/
*.swp
*.swo
*~
.DS_Store

# === Logs ===
*.log
logs/

# === Credentials ===
*.pem
*.key
.env
.env.*

# === Downloaded/Cached ===
*.tar.gz
*.zip
.download

# === QEMU/VM ===
*.qcow2
*.img
*.hdd
*.raw

# === Secrets ===
tentaclaw-secrets.yaml
node_credentials.txt
