#!/bin/bash
# TentaCLAW OS — One-Line Installer
# Usage: curl -fsSL tentaclaw.io/install | bash

set -euo pipefail

TEAL='\033[38;2;0;212;170m'
PURPLE='\033[38;2;139;92;246m'
GREEN='\033[38;2;0;255;136m'
RED='\033[31m'
DIM='\033[2m'
RESET='\033[0m'

echo ""
echo -e "${PURPLE}  ╭─────────────────────────────────────╮${RESET}"
echo -e "${PURPLE}  │${RESET}  ${TEAL}TentaCLAW OS${RESET} Installer              ${PURPLE}│${RESET}"
echo -e "${PURPLE}  │${RESET}  ${DIM}Eight arms. One mind. Zero config.${RESET}   ${PURPLE}│${RESET}"
echo -e "${PURPLE}  ╰─────────────────────────────────────╯${RESET}"
echo ""

# Check prerequisites
check_cmd() {
    if command -v "$1" &>/dev/null; then
        echo -e "  ${GREEN}[+]${RESET} $1 found"
        return 0
    else
        echo -e "  ${RED}[x]${RESET} $1 not found"
        return 1
    fi
}

MISSING=0
check_cmd git || MISSING=1
check_cmd node || MISSING=1
check_cmd npm || MISSING=1

if [ "$MISSING" -eq 1 ]; then
    echo ""
    echo -e "  ${RED}Missing prerequisites.${RESET} Install Node.js 22+ and git first:"
    echo -e "  ${DIM}  curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash -${RESET}"
    echo -e "  ${DIM}  sudo apt-get install -y nodejs git${RESET}"
    echo ""
    exit 1
fi

echo ""

# Clone or update
INSTALL_DIR="${HOME}/TentaCLAW"
if [ -d "$INSTALL_DIR" ]; then
    echo -e "  ${TEAL}[+]${RESET} Updating existing installation..."
    cd "$INSTALL_DIR" && git pull --quiet
else
    echo -e "  ${TEAL}[+]${RESET} Cloning TentaCLAW OS..."
    git clone --quiet https://github.com/TentaCLAW-OS/TentaCLAW.git "$INSTALL_DIR"
fi

cd "$INSTALL_DIR"

# Install dependencies
echo -e "  ${TEAL}[+]${RESET} Installing gateway dependencies..."
cd gateway && npm install --silent 2>/dev/null
cd ..

echo -e "  ${TEAL}[+]${RESET} Installing agent dependencies..."
cd agent && npm install --silent 2>/dev/null
cd ..

echo ""
echo -e "  ${GREEN}[+] TentaCLAW OS installed!${RESET}"
echo ""
echo -e "  ${TEAL}Start the gateway:${RESET}"
echo -e "    cd ${INSTALL_DIR}/gateway && npm run dev"
echo ""
echo -e "  ${TEAL}Start a mock agent:${RESET}"
echo -e "    cd ${INSTALL_DIR}/agent && npx tsx src/index.ts --mock"
echo ""
echo -e "  ${TEAL}Open dashboard:${RESET}"
echo -e "    http://localhost:8080/dashboard"
echo ""
echo -e "  ${DIM}CLAWtopus says: \"Welcome aboard. I've got arms for that.\" 🐙${RESET}"
echo ""
